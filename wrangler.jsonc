{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tokens-ug",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  }
}