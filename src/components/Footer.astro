---
// src/components/Footer.astro
import Logo from './Logo.astro';
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 mt-auto bg-surface-container-low dark:bg-surface-container-dark border-t border-outline-variant dark:border-outline-dark">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 px-4 md:px-8 max-w-7xl mx-auto">
    <div class="col-span-1 md:col-span-1">
      <div class="flex items-center gap-3 mb-4">
        <Logo class="w-8 h-8 text-primary" />
        <span class="font-headline-md text-headline-md text-on-surface dark:text-on-surface font-bold">
          Tokens@UG
        </span>
      </div>
      <p class="font-body-md text-body-md text-on-surface-variant opacity-80">
        © {currentYear} Tokens@UG. Built for high-frequency AI computation.
      </p>
    </div>
    <div>
      <h5 class="font-label-mono text-primary font-bold mb-4 uppercase tracking-wider">Resources</h5>
      <ul class="space-y-2">
        <li><a class="font-label-mono text-label-mono text-on-surface-variant hover:text-primary transition-colors" href="/docs">Documentation</a></li>
      </ul>
    </div>
    <div>
      <h5 class="font-label-mono text-primary font-bold mb-4 uppercase tracking-wider">Platform</h5>
      <ul class="space-y-2">
        <li><a class="font-label-mono text-label-mono text-on-surface-variant hover:text-primary transition-colors" href="/status">Status</a></li>
        <li><a class="font-label-mono text-label-mono text-on-surface-variant hover:text-primary transition-colors" href="/privacy">Privacy Policy</a></li>
      </ul>
    </div>
    <div>
      <h5 class="font-label-mono text-primary font-bold mb-4 uppercase tracking-wider">Connect</h5>
      <div class="flex gap-4">
        <a class="w-8 h-8 rounded-lg bg-surface-container dark:bg-surface-container-dark flex items-center justify-center text-on-surface-variant hover:text-primary transition-colors" href="mailto:contact@utilifygrid.com">
          <span class="material-symbols-outlined">terminal</span>
        </a>
        <a class="w-8 h-8 rounded-lg bg-surface-container dark:bg-surface-container-dark flex items-center justify-center text-on-surface-variant hover:text-primary transition-colors" href="mailto:contact@utilifygrid.com">
          <span class="material-symbols-outlined">hub</span>
        </a>
      </div>
    </div>
  </div>
</footer>