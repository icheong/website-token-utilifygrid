---
// src/components/Header.astro
import Logo from './Logo.astro';

interface Props {
  title?: string;
  activePage?: string;
}

const { title = "Tokens@UG", activePage = "" } = Astro.props;
---

<nav class="w-full top-0 sticky bg-surface dark:bg-surface-container-dark border-b border-outline-variant dark:border-outline-dark z-50 transition-all duration-200 ease-in-out">
  <div class="flex justify-between items-center px-4 md:px-8 py-4 max-w-7xl mx-auto">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-3">
        <Logo class="w-8 h-8 text-primary" />
        <span class="font-label-mono text-metric-display tracking-tight text-primary dark:text-primary-dark">
          {title}
        </span>
      </a>
      <div class="hidden md:flex gap-6 items-center">
        <a class={`font-body-md text-body-md ${activePage === 'models' ? 'text-primary border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-primary'} transition-colors duration-200`} href="/providers">
          Models
        </a>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="md:hidden text-on-surface-variant hover:text-primary transition-colors" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</nav>