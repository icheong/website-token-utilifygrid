---
// src/components/Logo.astro
interface Props {
  class?: string;
}

const { class: className = "w-8 h-8" } = Astro.props;
---

<svg 
  class={className} 
  viewBox="0 0 40 40" 
  fill="none" 
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Circle background -->
  <circle cx="20" cy="20" r="20" fill="currentColor" class="text-primary" />
  
  <!-- Bar chart -->
  <rect x="10" y="22" width="4" height="8" rx="1" fill="white" />
  <rect x="18" y="16" width="4" height="14" rx="1" fill="white" />
  <rect x="26" y="10" width="4" height="20" rx="1" fill="white" />
</svg>