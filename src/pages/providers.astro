---
import MainLayout from '../layouts/MainLayout.astro';
import ModelRegistry from '../components/ModelRegistry.jsx';
---
<MainLayout title="Models" description="Tokens@UG - AI Model Directory" activePage="models">
  <main class="flex flex-col md:flex-row gap-4 px-4 md:px-8 py-8 max-w-[1440px] mx-auto">
    <!-- Left Column: Technical Filters (25%) -->
    <aside class="w-full md:w-64 shrink-0 flex flex-col gap-3">
      <div class="flex flex-col gap-1 mb-2">
        <h2 class="font-headline-md text-[18px] text-primary">Technical Filters</h2>
        <p class="font-label-mono text-label-mono text-on-surface-variant opacity-70 uppercase tracking-wider">Refine search criteria</p>
      </div>
      <div class="bg-surface-container-low border border-outline-variant rounded-xl p-4 flex flex-col gap-6">
        <section>
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-[18px] text-secondary">data_object</span>
            <h3 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-tight">Context Window</h3>
          </div>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">4,096 tokens</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">32,768 tokens</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">128k+ tokens</span>
            </label>
          </div>
        </section>
        <section>
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-[18px] text-secondary">layers</span>
            <h3 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-tight">Model Class</h3>
          </div>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Compact (1B - 8B)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Mid-size (70B - 141B)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Expert (MoE / 400B+)</span>
            </label>
          </div>
        </section>
        <section>
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-[18px] text-secondary">hub</span>
            <h3 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-tight">Host Network</h3>
          </div>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Aggregators (Groq, Together)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Hyperscalers (AWS, GCP)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input class="w-4 h-4 rounded border-outline text-primary focus:ring-primary" type="checkbox"/>
              <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Decentralized Clusters</span>
            </label>
          </div>
        </section>
        <button class="w-full py-2 bg-surface-container-highest hover:bg-surface-variant text-on-surface-variant font-label-mono text-label-mono rounded-lg transition-colors border border-outline-variant">
          Reset All Filters
        </button>
      </div>
      <div class="p-4 bg-surface-container-lowest border border-outline-variant rounded-xl bg-primary-container-light/30">
        <div class="flex justify-between items-center mb-1">
          <span class="font-label-mono text-label-mono text-primary font-bold">Network Load</span>
          <span class="font-label-mono text-label-mono text-success">Optimal</span>
        </div>
        <div class="w-full bg-surface-container h-1 rounded-full overflow-hidden">
          <div class="bg-primary h-full w-[42%]"></div>
        </div>
      </div>
    </aside>

    <!-- Main Column: Model Directory (75%) - Fetched from Supabase -->
    <ModelRegistry client:load />
  </main>
</MainLayout>