---
import MainLayout from '../layouts/MainLayout.astro';
import SearchBar from '../components/SearchBar.jsx';
import TrendingMatchups from '../components/TrendingMatchups.jsx';
import LiveDashboard from '../components/LiveDashboard.jsx';
import LiveStats from '../components/LiveStats.jsx';
---
<MainLayout title="Home" description="Tokens@UG - Dynamic AI model pricing comparison platform">
  <!-- Hero Section - Matching Stitch homepage.html design -->
  <section class="max-w-7xl mx-auto px-4 md:px-8 pt-24 pb-16 text-center">
    <div class="mb-4 inline-block px-3 py-1 bg-surface-container rounded-full">
      <span class="font-label-mono text-label-mono text-on-surface-variant tracking-wider uppercase">
        v2.4.0 STABLE • REAL-TIME COST ANALYSIS • MULTI-PROVIDER BENCHMARKS
      </span>
    </div>
    <h1 class="font-headline-lg text-headline-lg text-on-surface mb-8 max-w-4xl mx-auto leading-tight">
      Compare raw API token rates across every inference provider
    </h1>
    
    <!-- Command Line Search - Functional React component -->
    <SearchBar client:load />
    
    <!-- Trending Matchups - Fetched from Supabase -->
    <TrendingMatchups client:load />
  </section>

  <!-- Data Section - Matching Stitch homepage.html design -->
  <section class="bg-surface-container-low py-24">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-headline-md text-headline-md text-on-surface mb-6">Data-driven decisions for your AI architecture</h2>
        <p class="font-body-md text-body-md text-on-surface-variant mb-10 leading-relaxed max-w-lg">
          Stop guessing about token overhead. Our protocol monitors latency spikes and pricing shifts across 40+ endpoints every minute, giving you the edge in inference optimization.
        </p>
        <div class="grid grid-cols-2 gap-6">
          <LiveStats client:load />
        </div>
      </div>
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary-container/20 to-transparent rounded-3xl"></div>
        <div class="relative bg-surface-container-lowest border border-outline-variant rounded-2xl p-8 shadow-lg">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-lg bg-primary-container-light flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">analytics</span>
            </div>
            <div>
              <h4 class="font-headline-md text-headline-md">Real-time Dashboard</h4>
              <p class="text-body-md text-on-surface-variant">Live pricing feeds</p>
            </div>
          </div>
          <div class="space-y-4">
            <LiveDashboard client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section - Matching Stitch design -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-16">
        <h2 class="font-headline-md text-headline-md text-on-surface mb-4">Built for developers who ship</h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">
          Everything you need to optimize your AI inference costs and performance.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-6 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary-container transition-colors">
          <div class="w-12 h-12 rounded-lg bg-primary-container-light flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-primary">speed</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-2">Real-time Pricing</h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Live price feeds from 40+ providers, updated every 60 seconds.
          </p>
        </div>
        <div class="p-6 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary-container transition-colors">
          <div class="w-12 h-12 rounded-lg bg-secondary-container/20 flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-secondary">compare_arrows</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-2">Side-by-Side Comparison</h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Compare costs, latency, and throughput across providers.
          </p>
        </div>
        <div class="p-6 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary-container transition-colors">
          <div class="w-12 h-12 rounded-lg bg-tertiary-fixed flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-tertiary">bolt</span>
          </div>
          <h3 class="font-headline-md text-headline-md mb-2">Cost Optimization</h3>
          <p class="font-body-md text-body-md text-on-surface-variant">
            Find the cheapest provider for your specific usage pattern.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>