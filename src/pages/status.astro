---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="System Status" description="Tokens@UG system status and uptime monitoring">
  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12">
    <div class="mb-8">
      <h1 class="font-headline-lg text-headline-lg text-on-surface mb-4">System Status</h1>
      <p class="font-body-md text-body-md text-on-surface-variant">
        Current status and uptime monitoring for all Tokens@UG services.
      </p>
    </div>

    <div class="space-y-6">
      <!-- Overall Status -->
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-3 h-3 rounded-full bg-success animate-pulse"></div>
          <h2 class="font-headline-md text-headline-md text-on-surface">All Systems Operational</h2>
        </div>
        <p class="font-body-md text-body-md text-on-surface-variant">
          All services are running normally. Last updated: {new Date().toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
        </p>
      </div>

      <!-- Services -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">dns</span>
          Services
        </h3>
        <div class="divide-y divide-outline-variant">
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">API Endpoint</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">tokens.ugifygrid.com/api</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Pricing Database</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Supabase PostgreSQL</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Web Application</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Cloudflare Pages</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Data Sync Worker</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Cloudflare Workers</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
        </div>
      </section>

      <!-- Uptime -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">timeline</span>
          Uptime History
        </h3>
        <div class="grid grid-cols-7 gap-1 mb-4">
          {Array.from({ length: 28 }, (_, i) => (
            <div class="h-8 rounded bg-success/80 hover:bg-success transition-colors cursor-pointer" title={`Day ${28 - i}: 100%`}></div>
          ))}
        </div>
        <div class="flex justify-between text-label-mono text-label-mono text-on-surface-variant">
          <span>28 days ago</span>
          <span class="text-success font-bold">99.98% uptime</span>
          <span>Today</span>
        </div>
      </section>

      <!-- Recent Incidents -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">incident_history</span>
          Recent Incidents
        </h3>
        <div class="text-center py-8">
          <span class="material-symbols-outlined text-success text-4xl mb-2">check_circle</span>
          <p class="font-body-md text-body-md text-on-surface-variant">No incidents reported in the last 30 days.</p>
        </div>
      </section>

      <!-- Maintenance -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">build</span>
          Scheduled Maintenance
        </h3>
        <div class="text-center py-8">
          <span class="material-symbols-outlined text-on-surface-variant text-4xl mb-2">event_available</span>
          <p class="font-body-md text-body-md text-on-surface-variant">No scheduled maintenance at this time.</p>
        </div>
      </section>
    </div>
  </main>
</MainLayout>
