---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="System Status" description="Tokens@UG system status and uptime monitoring">
  <main class="max-w-4xl mx-auto px-4 md:px-8 py-12">
    <div class="mb-8">
      <h1 class="font-headline-lg text-headline-lg text-on-surface mb-4">System Status</h1>
      <p class="font-body-md text-body-md text-on-surface-variant">
        Current status and uptime monitoring for all Tokens@UG services.
      </p>
    </div>

    <div class="space-y-6">
      <!-- Overall Status -->
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-3 h-3 rounded-full bg-success animate-pulse"></div>
          <h2 class="font-headline-md text-headline-md text-on-surface">All Systems Operational</h2>
        </div>
        <p class="font-body-md text-body-md text-on-surface-variant">
          All services are running normally. Last updated: {new Date().toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
        </p>
      </div>

      <!-- Services -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">dns</span>
          Services
        </h3>
        <div class="divide-y divide-outline-variant">
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">API Endpoint</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">tokens.ugifygrid.com/api</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Pricing Database</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Supabase PostgreSQL</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Web Application</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Cloudflare Pages</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
              <div>
                <p class="font-body-md text-body-md text-on-surface font-medium">Data Sync Worker</p>
                <p class="font-label-mono text-label-mono text-on-surface-variant">Cloudflare Workers</p>
              </div>
            </div>
            <span class="font-label-mono text-label-mono text-success">Operational</span>
          </div>
        </div>
      </section>

      <!-- Uptime -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">timeline</span>
          Uptime History
        </h3>
        <div class="grid grid-cols-7 gap-1 mb-4">
          {Array.from({ length: 28 }, (_, i) => (
            <div class="h-8 rounded bg-success/80 hover:bg-success transition-colors cursor-pointer" title={`Day ${28 - i}: 100%`}></div>
          ))}
        </div>
        <div class="flex justify-between text-label-mono text-label-mono text-on-surface-variant">
          <span>28 days ago</span>
          <span class="text-success font-bold">99.98% uptime</span>
          <span>Today</span>
        </div>
      </section>

      <!-- Recent Incidents -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">incident_history</span>
          Recent Incidents
        </h3>
        <div class="text-center py-8">
          <span class="material-symbols-outlined text-success text-4xl mb-2">check_circle</span>
          <p class="font-body-md text-body-md text-on-surface-variant">No incidents reported in the last 30 days.</p>
        </div>
      </section>

      <!-- Maintenance -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">build</span>
          Scheduled Maintenance
        </h3>
        <div class="text-center py-8">
          <span class="material-symbols-outlined text-on-surface-variant text-4xl mb-2">event_available</span>
          <p class="font-body-md text-body-md text-on-surface-variant">No scheduled maintenance at this time.</p>
        </div>
      </section>

      <!-- Data Sources -->
      <section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
        <h3 class="font-headline-md text-headline-md text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">database</span>
          Data Sources
        </h3>
        <p class="font-body-md text-body-md text-on-surface-variant mb-4">
          Pricing data is sourced directly from provider APIs and aggregated endpoints. Prices are synced regularly and verified against official documentation.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <a href="https://openai.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">OA</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">OpenAI</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">openai.com</p>
            </div>
          </a>
          <a href="https://anthropic.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">An</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Anthropic</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">anthropic.com</p>
            </div>
          </a>
          <a href="https://ai.google.dev" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">G</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Google</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">ai.google.dev</p>
            </div>
          </a>
          <a href="https://deepinfra.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">DI</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">DeepInfra</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">deepinfra.com</p>
            </div>
          </a>
          <a href="https://deepseek.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">DS</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">DeepSeek</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">deepseek.com</p>
            </div>
          </a>
          <a href="https://mistral.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">Mi</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Mistral</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">mistral.ai</p>
            </div>
          </a>
          <a href="https://llama.meta.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">Me</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Meta</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">llama.meta.com</p>
            </div>
          </a>
          <a href="https://together.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">TA</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Together AI</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">together.ai</p>
            </div>
          </a>
          <a href="https://groq.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">Gr</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Groq</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">groq.com</p>
            </div>
          </a>
          <a href="https://fireworks.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">FW</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Fireworks AI</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">fireworks.ai</p>
            </div>
          </a>
          <a href="https://nvidia.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">Nv</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">NVIDIA</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">nvidia.com</p>
            </div>
          </a>
          <a href="https://microsoft.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">MS</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Microsoft</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">microsoft.com</p>
            </div>
          </a>
          <a href="https://openrouter.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">OR</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">OpenRouter</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">openrouter.ai</p>
            </div>
          </a>
          <a href="https://artificialanalysis.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/50 hover:border-primary/50 hover:bg-surface-container-low transition-colors">
            <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center font-bold text-on-surface-variant text-xs">AA</div>
            <div>
              <p class="font-body-md text-body-md text-on-surface font-medium">Artificial Analysis</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant">artificialanalysis.ai</p>
            </div>
          </a>
        </div>
      </section>
    </div>
  </main>
</MainLayout>
