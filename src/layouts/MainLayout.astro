---
// src/layouts/MainLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { title, description = "Tokens@UG - Dynamic AI model pricing comparison platform", activePage = "" } = Astro.props;
---
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Tokens@UG</title>
    <meta name="description" content={description} />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background text-on-surface font-body-md h-full flex flex-col antialiased dark:bg-surface-container-dark dark:text-slate-100">
    <Header title="Tokens@UG" activePage={activePage} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>